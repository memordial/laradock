{
    "name": "laradock/php-version-manager",
    "description": "PHP Version Manager for Laradock development environments",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Laradock\\PHPVersionManager\\": "src/PHPVersionManager/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laradock\\PHPVersionManager\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "giorgiosironi/eris": "^0.14"
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    }
}